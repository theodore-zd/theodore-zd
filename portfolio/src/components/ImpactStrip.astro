---
import SectionLabel from "./SectionLabel.astro"
import StatCard from "./StatCard.astro"
---

<section class="border-b border-border py-12">
  <div class="mx-auto max-w-6xl px-6">
    <SectionLabel label="impact" />
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <StatCard percentage="43%" title="UI/UX Improvement" description="User testing scores increased through design system implementation" delay={100} />
      <StatCard percentage="65%" title="User Adoption Increase" description="Led comprehensive redesign that drove significant adoption growth" delay={200} />
      <StatCard percentage="33%" title="Faster Development Cycles" description="Built reusable components and design systems that accelerated delivery" delay={300} />
      <StatCard percentage="53%" title="Organic Traffic Growth" description="Achieved 95+ Lighthouse scores with performance-optimized sites" delay={400} />
    </div>
  </div>
</section>
