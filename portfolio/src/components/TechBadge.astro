---
import { getTechIcon } from "@/lib/tech-icons"

interface Props {
  tech: string
  class?: string
}

const { tech, class: className = "" } = Astro.props
const icon = getTechIcon(tech)
---

<span class:list={["inline-flex items-center gap-1 text-xs", className]}>
  {icon && (
    <svg role="img" viewBox="0 0 24 24" class="size-3 fill-muted-foreground">
      <path d={icon.path} />
    </svg>
  )}
  {tech}
</span>
