---
import { resume } from "@/data/resume"
import { getTechIcon } from "@/lib/tech-icons"
import StarWarsFalcon from "./StarWarsFalcon.astro"
import StatusLabel from "./StatusLabel.astro"

const valueProps = resume.valueProps || [
    "Frontend: React, Next.js, TypeScript, Tailwind",
    "Backend: Node.js, Python, Go, PostgreSQL",
    "DevOps: Docker, CI/CD, cloud deployment"
]
---

<section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 from-primary/5 via-transparent to-transparent" />
    <div class="absolute inset-0 dot-pattern opacity-50" />
    
    <div class="relative mx-auto max-w-6xl px-6 py-20 md:py-32">
        <div class="flex max-w-3xl flex-col gap-1">
            <StatusLabel label=" --available" />
            
            <p class="animate-fade-up delay-100 text-lg text-muted-foreground md:text-2xl">Hi, my name is</p>
            
            <h1 class="animate-fade-up delay-200 text-4xl font-bold tracking-tight md:text-6xl py-2">
                {resume.name}
            </h1>
            
            <p class="animate-fade-up delay-300 text-xl text-muted-foreground md:text-2xl pb-4">
                {resume.headline || resume.tagline}<span class="cursor-blink"></span>
            </p>
            
            <ul class="animate-fade-up delay-400 flex flex-col gap-3 pt-2">
                {valueProps.map((prop) => {
                    // Extract tech names mentioned in the prop for inline icons
                    const techNames = ["React", "Next.js", "TypeScript", "Node.js", "Python", "Go", "PostgreSQL", "MongoDB", "Docker", "CI/CD"]
                    const foundIcons = techNames.filter(t => prop.includes(t)).map(t => ({ name: t, icon: getTechIcon(t) })).filter(t => t.icon)
                    return (
                        <li class="flex items-center gap-2 text-sm text-muted-foreground">
                            <span class="text-primary font-bold shrink-0">{'>'}</span>
                            <span>{prop}</span>
                            {foundIcons.length > 0 && (
                                <span class="flex items-center gap-1.5 ml-1 opacity-50">
                                    {foundIcons.map(({ icon }) => (
                                        <svg role="img" viewBox="0 0 24 24" class="size-3.5 fill-muted-foreground">
                                            <path d={icon!.path} />
                                        </svg>
                                    ))}
                                </span>
                            )}
                        </li>
                    )
                })}
            </ul>
            
            <div class="animate-fade-up delay-500 flex flex-wrap gap-4 pt-4">
                <a 
                    href={`mailto:${resume.email}`}
                    class="inline-flex shrink-0 items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/80 hover:glow-primary focus-visible:border-ring focus-visible:ring-1 focus-visible:ring-ring/50"
                >
                    Let's Talk
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </a>
                <a 
                    href={resume.resumeUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="terminal-card inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-border bg-background px-6 py-3 text-sm font-medium transition-all hover:text-primary focus-visible:border-ring focus-visible:ring-1 focus-visible:ring-ring/50"
                >
                    Resume
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
    </div>
</section>
