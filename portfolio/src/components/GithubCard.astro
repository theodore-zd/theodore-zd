---
import { siGithub } from "simple-icons"
import Card from "./Card.astro"
import CardContent from "./CardContent.astro"
import { languageColor, type GithubProject } from "@/data/githubProjects"

interface Props {
  project: GithubProject
  class?: string
}

const { project, class: className = "" } = Astro.props
const { repo, description, language, stars, forks, homepage } = project
const href = `https://github.com/${repo}`
const langColor = languageColor(language)
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["block h-full hover:no-underline", className]}
>
  <Card class="group rounded-lg h-full border border-accent transition-transform hover:border-primary hover:shadow hover:scale-105 hover:-rotate-3">
    <CardContent class="flex h-full flex-col gap-4 p-6">
      <div class="flex items-start gap-2">
        <svg role="img" viewBox="0 0 24 24" class="size-5 shrink-0 fill-foreground mt-0.5">
          <path d={siGithub.path} />
        </svg>
        <h3 class="flex-1 text-base font-semibold break-all leading-tight">
          {repo}
        </h3>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4 shrink-0 text-muted-foreground mt-1 transition-transform group-hover:text-primary group-hover:scale-130  "
          aria-hidden="true"
        >
          <path d="M7 17L17 7" />
          <path d="M8 7h9v9" />
        </svg>
      </div>

      <p class="text-sm text-muted-foreground line-clamp-3">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 mt-auto text-xs text-muted-foreground">
        {language && (
          <span class="inline-flex items-center gap-1.5">
            <span
              class="inline-block size-2.5 rounded-full"
              style={`background-color: ${langColor}`}
              aria-hidden="true"
            ></span>
            <span>{language}</span>
          </span>
        )}
        <span class="inline-flex items-center gap-1" title="Stars">
          <svg viewBox="0 0 16 16" class="size-3.5 fill-current" aria-hidden="true">
            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.72 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.767 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
          </svg>
          {stars}
        </span>
        <span class="inline-flex items-center gap-1" title="Forks">
          <svg viewBox="0 0 16 16" class="size-3.5 fill-current" aria-hidden="true">
            <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
          </svg>
          {forks}
        </span>
        {homepage && (
          <span class="inline-flex items-center gap-1 ml-auto text-primary" title="Homepage">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20"/>
              <path d="M12 2a15 15 0 0 1 0 20"/>
              <path d="M12 2a15 15 0 0 0 0 20"/>
            </svg>
            live
          </span>
        )}
      </div>
    </CardContent>
  </Card>
</a>
