---
interface Props {
  class?: string
}
const { class: className = "" } = Astro.props
---

<div class:list={[" ", className]}>
  <div class="relative group">
    <span
      class="pointer-events-none absolute right-full top-1/2 -translate-y-1/2 mr-3 whitespace-nowrap rounded border border-border bg-card px-2 py-1 text-xs text-muted-foreground opacity-0 transition-opacity duration-150 group-hover:opacity-100"
    >
      activate hyperdrive
    </span>
    <button
      id="falcon-button"
      class="cursor-pointer bg-transparent border-0 p-0"
      type="button"
      aria-label="Activate hyperdrive"
    >
      <div class="w-25 h-25 relative z-[99] transition-transform duration-200 group-hover:scale-110">
        <div id="falcon-container">
          <img
            src="/MillenniumFalconDesk_3.webp"
            alt="Millennium Falcon"
            class="transform rotate-45"
          />
        </div>
      </div>
    </button>
  </div>

  <audio id="falcon-sound" preload="auto">
    <source src="/falcon-jump.mp3" type="audio/mpeg" />
  </audio>
</div>

<script>
  const button = document.getElementById("falcon-button")
  const container = document.getElementById("falcon-container")
  const sound = document.getElementById("falcon-sound") as HTMLAudioElement

  if (button && container && sound) {
    button.addEventListener("click", () => {
      sound.volume = 0.05
      sound.playbackRate = 1
      sound.play()

      container.classList.add("falcon-exit")

      setTimeout(() => {
        container.classList.remove("falcon-exit")
        container.classList.add("falcon-enter")
      }, 3000)

      setTimeout(() => {
        container.classList.remove("falcon-enter")
      }, 5000)
    })
  }
</script>
