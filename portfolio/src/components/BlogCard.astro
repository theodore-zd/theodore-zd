---
import Card from "./Card.astro"
import CardContent from "./CardContent.astro"

interface Props {
    post: {
        id: string
        data: {
            title: string
            description: string
            date: Date
            tags: string[]
            readTime?: string
            thumbnail?: string
            thumbnailAlt?: string
        }
    }
    class?: string
}

const { post, class: className = "" } = Astro.props
const { title, description, date, tags, readTime, thumbnail, thumbnailAlt } = post.data

function formatDate(d: Date) {
    return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
}
---

<a
    href={`/blog/${post.id}`}
    class:list={["block h-full hover:no-underline", className]}
>
    <Card class="group flex h-full flex-col overflow-hidden rounded-lg border border-accent transition-transform hover:border-primary hover:shadow hover:scale-105 hover:-rotate-3">
        <div class="relative aspect-[16/9] overflow-hidden border-b border-border bg-muted">
            <img
                src={thumbnail ?? "/blog-placeholder.svg"}
                alt={thumbnailAlt ?? title}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
        </div>

        <CardContent class="flex flex-1 flex-col gap-3 p-6">
            <p class="text-sm text-muted-foreground line-clamp-3">
                {description}
            </p>

            <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-1.5 pt-2 text-xs text-muted-foreground">
                <time class="inline-flex items-center gap-1.5 font-mono">
                    <span class="inline-block size-2.5 rounded-full bg-primary/70" aria-hidden="true"></span>
                    {formatDate(date)}
                </time>
                {readTime && (
                    <span class="inline-flex items-center gap-1" title="Read time">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M12 6v6l4 2" />
                        </svg>
                        {readTime}
                    </span>
                )}
                {tags.length > 0 && (
                    <span class="ml-auto inline-flex flex-wrap justify-end gap-1">
                        {tags.slice(0, 2).map((tag) => (
                            <span class="inline-flex items-center rounded-md bg-muted/60 px-2 py-0.5 text-[10px] uppercase tracking-wide text-muted-foreground">
                                {tag}
                            </span>
                        ))}
                    </span>
                )}
            </div>
        </CardContent>
    </Card>
</a>
