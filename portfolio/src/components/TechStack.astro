---
import { resume } from "@/data/resume"
import { getTechIcon } from "@/lib/tech-icons"
import SectionLabel from "./SectionLabel.astro"

const { skills = resume.skills } = Astro.props
---

<section class="border-b border-border py-24">
  <div class="mx-auto max-w-6xl px-6">
    <SectionLabel label="tech stack" />

    <!-- Core Stack - with icons -->
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {
        skills.favorite.map((tech: string, i: number) => {
          const icon = getTechIcon(tech)
          return (
            <div
              class={`flex items-center gap-3 rounded border border-border bg-card/40 px-3 py-2.5 animate-fade-up`}
              style={`animation-delay: ${i * 60}ms`}
            >
              <span class="flex size-7 shrink-0 items-center justify-center rounded bg-primary/10 text-primary">
                {icon ? (
                  <svg
                    role="img"
                    viewBox="0 0 24 24"
                    class="size-4 fill-primary"
                  >
                    <path d={icon.path} />
                  </svg>
                ) : (
                  <span class="text-xs font-bold">λ</span>
                )}
              </span>
              <span class="text-sm font-medium tracking-tight">{tech}</span>
            </div>
          )
        })
      }
    </div>

    <!-- Toolbox - compact with import style -->
    <div class="mt-10 mb-3">
      <p class="text-xs text-muted-foreground">
        <span class="text-primary">import</span>
        {"{"}
      </p>
    </div>

    <div class="flex flex-wrap gap-1.5">
      {
        skills.toolbox.map((tool: string) => {
          const icon = getTechIcon(tool)
          return (
             <span class="inline-flex items-center gap-1.5 rounded border border-border/50 bg-muted/30 px-2 py-1 text-xs text-muted-foreground">
              {icon && (
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  class="size-3 fill-muted-foreground/60"
                >
                  <path d={icon.path} />
                </svg>
              )}
              {tool}
            </span>
          )
        })
      }
    </div>

    <div class="mt-3 mb-3">
      <p class="text-xs text-muted-foreground">
        {"}"}
        <span class="text-primary">from</span>
        <span class="text-primary">"~/toolbox"</span>
      </p>
    </div>
  </div>
</section>
