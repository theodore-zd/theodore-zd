---
interface Props {
    label: string
}

const { label } = Astro.props
---
<span class="animate-fade-up w-fit gap-2 mb-8 border border-primary/30 bg-primary/5 px-3 py-1 font-mono inline-flex items-center rounded-md">
  <span class="h-2 w-2 animate-pulse rounded-full bg-primary" />
  $ status {label}
</span>
