---
import Layout from "@/layouts/main.astro"
import { getCollection } from "astro:content"
import { resume } from "@/data/resume"
import { site } from "@/data/site"
import SectionLabel from "@/components/SectionLabel.astro"
import BlogCard from "@/components/BlogCard.astro"

const posts = (
    await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout title={site.blog.title} description={site.blog.description}>
    <section class="border-b border-border py-24">
        <div class="mx-auto max-w-6xl px-6">
            <SectionLabel label="blog" />

            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {posts.map((post, index) => (
                    <div class:list={["h-full animate-fade-up", `delay-${((index % 3) + 1) * 100}`]}>
                        <BlogCard post={post} />
                    </div>
                ))}
            </div>

            <div class="mt-32 rounded-lg border border-border p-8 text-center">
                <p class="text-sm text-muted-foreground mb-4">
                    Want to discuss an article or have a question?
                </p>
                <a
                    href={`mailto:${resume.email}`}
                    class="inline-flex items-center gap-2 text-sm font-medium text-primary link-underline"
                >
                    <span class="text-primary/70">$</span>
                    Get in touch
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
        </div>
    </section>
</Layout>
