{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:proxy.golang.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go test:*)",
      "FileRead(~/.gitconfig)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        ".",
        "~/.1password/agent.sock",
        "~/.gitconfig"
      ]
    }
  }
}
